{
    "name": "FlowDesk Extension",
    "description": "A Chrome extension for keeping yourself focused on your work. Being in flowstate.",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": [
        "storage"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "images/icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "scripts/blocker.js"
            ],
            "run_at": "document_start"
        }
    ]
}